.env

# Logs
storage/logs/*
!storage/logs/.gitkeep

# Cache
storage/cache/*
!storage/cache/.gitkeep

# Uploaded files
storage/avatars/*
storage/avatars/members/*
storage/avatars/users/*
storage/covers/*
storage/covers/books/*
!storage/avatars/.gitkeep
!storage/avatars/members/.gitkeep
!storage/avatars/users/.gitkeep
!storage/covers/.gitkeep
!storage/covers/books/.gitkeep

# macOS
.DS_Store
